<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Empório São Vicente · Franca-SP</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --ink:#06040E;
  --cream:#F2EDE4;
  --red:#C8282A;
  --gold:#BF8B2E;
  --amber:#E0A030;
  --line:rgba(242,237,228,0.1);
}
html{overflow-x:hidden}
body{background:var(--ink);color:var(--cream);font-family:'DM Sans',sans-serif;overflow-x:hidden;cursor:none}

/* ─ CURSOR ─ */
#cur{position:fixed;width:12px;height:12px;background:var(--cream);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:difference;transition:width .3s,height .3s}
#cur.big{width:60px;height:60px}
#cur-ring{position:fixed;width:40px;height:40px;border:1px solid rgba(242,237,228,0.3);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%)}

/* ─ LOADER ─ */
#loader{position:fixed;inset:0;background:var(--ink);z-index:8000;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0}
.ld-word{font-family:'Bebas Neue',sans-serif;font-size:clamp(50px,11vw,130px);letter-spacing:0.1em;overflow:hidden;line-height:1.05}
.ld-word span{display:block;transform:translateY(110%)}
.ld-sub{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:0.4em;text-transform:uppercase;color:rgba(242,237,228,0.3);margin-top:14px;overflow:hidden}
.ld-sub span{display:block;transform:translateY(120%)}
.ld-progress{width:0;height:1px;background:linear-gradient(90deg,var(--gold),transparent);margin-top:40px;transition:width 1.4s ease}

/* ─ NAV ─ */
nav{position:fixed;top:0;left:0;right:0;z-index:500;padding:24px 48px;display:flex;justify-content:space-between;align-items:center;transition:background .4s}
nav.scrolled{background:rgba(6,4,14,0.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--line)}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:0.2em;color:var(--cream);text-decoration:none}
.nav-r{display:flex;align-items:center;gap:28px}
.nav-lk{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(242,237,228,0.45);text-decoration:none;transition:color .2s}
.nav-lk:hover{color:var(--cream)}
.nav-btn{font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:0.2em;background:var(--cream);color:var(--ink);padding:10px 22px;text-decoration:none;transition:opacity .2s}
.nav-btn:hover{opacity:.8}

/* ─ SCENE (full-bleed visual panel) ─ */
.scene{position:relative;height:100vh;min-height:600px;overflow:hidden;display:flex;align-items:flex-end}
.scene-bg{position:absolute;inset:-10%;will-change:transform}
/* vignette */
.scene-vignette{position:absolute;inset:0;z-index:1}
.scene-grain{position:absolute;inset:0;z-index:2;pointer-events:none;opacity:.5;mix-blend-mode:overlay;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.12'/%3E%3C/svg%3E")}
.scene-content{position:relative;z-index:3;padding:0 48px 80px;width:100%}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   SCENE BACKGROUNDS — canvas SVG art
   Each uses a <canvas> that gets rendered via JS
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
.scene-bg canvas{width:100%;height:100%;display:block}

/* ─ HERO TEXT ─ */
.hero-kicker{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.3em;text-transform:uppercase;color:var(--amber);margin-bottom:24px;opacity:0}
.hero-h{font-family:'Bebas Neue',sans-serif;font-size:clamp(72px,13vw,180px);line-height:.88;letter-spacing:-.01em}
.hero-h .hl{display:block;overflow:hidden}
.hero-h .hl span{display:block;transform:translateY(110%)}
.hero-h .stroke{-webkit-text-stroke:1.5px var(--cream);color:transparent}
.hero-h .red{color:var(--red)}
.hero-foot{display:flex;justify-content:space-between;align-items:flex-end;margin-top:40px;opacity:0}
.hero-desc{font-size:14px;color:rgba(242,237,228,0.4);max-width:300px;line-height:1.7}
.hero-actions{display:flex;flex-direction:column;align-items:flex-end;gap:10px}
.scroll-hint{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:rgba(242,237,228,0.25);writing-mode:vertical-rl}

/* ─ BUTTONS ─ */
.btn-wpp{display:inline-flex;align-items:center;gap:10px;background:#25D366;color:#fff;font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:.18em;text-decoration:none;padding:14px 28px;position:relative;overflow:hidden;transition:transform .2s}
.btn-wpp::before{content:'';position:absolute;inset:0;background:rgba(255,255,255,.15);transform:translateX(-110%) skewX(-15deg);transition:transform .4s}
.btn-wpp:hover::before{transform:translateX(110%) skewX(-15deg)}
.btn-wpp:hover{transform:scale(1.03)}
.btn-ghost{display:inline-flex;align-items:center;gap:10px;background:transparent;color:var(--cream);font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:.18em;text-decoration:none;padding:14px 28px;border:1px solid rgba(242,237,228,0.2);transition:all .25s}
.btn-ghost:hover{border-color:var(--cream);background:rgba(242,237,228,0.05)}

/* ─ TICKER ─ */
.ticker{border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:10px 0;overflow:hidden;position:relative;z-index:2}
.t-track{display:flex;white-space:nowrap;animation:tick 30s linear infinite}
.t-item{font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:.2em;color:rgba(242,237,228,0.18);padding:0 48px;flex-shrink:0}
.t-item em{color:var(--amber);font-style:normal}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ─ STATEMENT ─ */
.stmt-label{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.4em;text-transform:uppercase;color:var(--amber);margin-bottom:28px}
.stmt-h{font-family:'Bebas Neue',sans-serif;font-size:clamp(52px,9vw,130px);line-height:.9;letter-spacing:-.01em;text-align:center}
.stmt-h .out{-webkit-text-stroke:1px rgba(242,237,228,.35);color:transparent}
.stmt-h .acc{color:var(--red)}

/* ─ PRODUCTS ─ */
.products-wrap{position:relative;padding:100px 48px;background:var(--ink);overflow:hidden}
.products-wrap::after{content:'';position:absolute;top:0;right:0;bottom:0;width:38%;pointer-events:none;z-index:0}
.prod-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:60px;border-bottom:1px solid var(--line);padding-bottom:24px;position:relative;z-index:1}
.prod-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(44px,7vw,88px);letter-spacing:-.01em;line-height:1}
.prod-count{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:rgba(242,237,228,.3)}
.p-row{display:grid;grid-template-columns:44px 1fr auto auto 170px;gap:24px;align-items:center;padding:24px 0;border-bottom:1px solid var(--line);text-decoration:none;color:inherit;position:relative;overflow:hidden;transition:padding-left .3s;z-index:1}
.p-row::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,rgba(191,139,46,.06),transparent);transform:translateX(-100%);transition:transform .35s}
.p-row:hover{padding-left:20px}
.p-row:hover::after{transform:translateX(0)}
.p-row:hover .p-name{color:var(--amber)}
.p-num{font-family:'JetBrains Mono',monospace;font-size:10px;color:rgba(242,237,228,.18);letter-spacing:.08em}
.p-name{font-family:'Bebas Neue',sans-serif;font-size:clamp(22px,2.8vw,38px);letter-spacing:.02em;line-height:1;transition:color .2s}
.p-badge{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.15em;text-transform:uppercase;padding:5px 10px;border:1px solid;white-space:nowrap}
.b-hot{color:var(--red);border-color:rgba(200,40,42,.3)}
.b-best{color:var(--amber);border-color:rgba(191,139,46,.3)}
.b-new{color:rgba(242,237,228,.35);border-color:rgba(242,237,228,.12)}
.p-price{text-align:right}
.p-old{font-family:'JetBrains Mono',monospace;font-size:10px;color:rgba(242,237,228,.2);text-decoration:line-through;display:block;margin-bottom:4px}
.p-new{font-family:'JetBrains Mono',monospace;font-size:26px;font-weight:700;color:var(--amber);letter-spacing:-.02em;line-height:1}
.p-btn{background:transparent;border:1px solid rgba(242,237,228,.12);color:rgba(242,237,228,.4);font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:.15em;padding:12px 18px;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .25s;white-space:nowrap}
.p-btn:hover{background:var(--red);border-color:var(--red);color:#fff}
#pv{position:fixed;pointer-events:none;z-index:300;width:200px;height:250px;display:flex;align-items:center;justify-content:center;font-size:88px;transform:translate(-50%,-60%) scale(0) rotate(-6deg);opacity:0;background:rgba(8,6,18,.92);border:1px solid var(--line);backdrop-filter:blur(16px);transition:transform .3s cubic-bezier(.23,1,.32,1),opacity .25s;will-change:transform}
#pv.show{transform:translate(-50%,-60%) scale(1) rotate(0deg);opacity:1}

/* ─ COMBO ─ */
.combo-card{max-width:560px;background:rgba(6,4,14,.8);backdrop-filter:blur(28px);border:1px solid rgba(242,237,228,.1);padding:52px 48px}
.combo-eyebrow{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.4em;text-transform:uppercase;color:var(--amber);margin-bottom:14px}
.combo-num-big{font-family:'Bebas Neue',sans-serif;font-size:clamp(80px,12vw,140px);line-height:.85;letter-spacing:-.03em;-webkit-text-stroke:1px rgba(242,237,228,.12);color:transparent;margin-bottom:-16px}
.combo-h{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,5vw,56px);line-height:.95;letter-spacing:-.01em;margin-bottom:28px}
.combo-h span{color:var(--red)}
.combo-pills{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:32px}
.c-pill{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.15em;text-transform:uppercase;color:rgba(242,237,228,.4);border:1px solid var(--line);padding:7px 12px}
.combo-price-line{display:flex;align-items:baseline;gap:16px;margin-bottom:10px}
.combo-from{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:rgba(242,237,228,.25)}
.combo-amount{font-family:'Bebas Neue',sans-serif;font-size:clamp(56px,7vw,80px);color:var(--amber);letter-spacing:-.02em;line-height:1}
.combo-save{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--red);letter-spacing:.1em;margin-bottom:36px}

/* ─ CATEGORIES ─ */
.cats-wrap{position:relative;background:var(--ink);overflow:hidden}
.cats-content{position:relative;z-index:1;padding:100px 48px}
.cat-top{margin-bottom:60px;border-bottom:1px solid var(--line);padding-bottom:24px;display:flex;justify-content:space-between;align-items:baseline}
.cat-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(40px,6vw,76px);letter-spacing:-.01em;line-height:1}
.cat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line)}
.c-cell{background:var(--ink);padding:44px 28px;display:flex;flex-direction:column;gap:16px;text-decoration:none;color:inherit;position:relative;overflow:hidden;transition:background .3s}
.c-cell::after{content:'';position:absolute;bottom:0;left:0;width:100%;height:2px;background:var(--amber);transform:scaleX(0);transform-origin:left;transition:transform .35s}
.c-cell:hover{background:rgba(242,237,228,.025)}
.c-cell:hover::after{transform:scaleX(1)}
.c-cell:hover .ci{transform:scale(1.12) translateY(-4px)}
.ci{font-size:28px;transition:transform .3s;display:block}
.c-name{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.05em}
.c-arr{position:absolute;bottom:20px;right:20px;font-size:14px;color:rgba(242,237,228,.12);transition:transform .25s,color .25s}
.c-cell:hover .c-arr{transform:translate(3px,-3px);color:var(--amber)}

/* ─ PROOF ─ */
.proof-nums{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(242,237,228,.06)}
.pn-cell{background:rgba(6,4,14,.65);backdrop-filter:blur(10px);padding:36px 28px}
.pn-num{font-family:'Bebas Neue',sans-serif;font-size:52px;color:var(--amber);line-height:1;margin-bottom:8px}
.pn-lbl{font-size:12px;color:rgba(242,237,228,.4);line-height:1.6}
.reviews-wrap{padding:80px 48px;background:var(--ink);border-top:1px solid var(--line)}
.rv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1300px;margin:48px auto 0}
.rv-card{border:1px solid var(--line);padding:32px;position:relative;overflow:hidden}
.rv-card::before{content:'"';position:absolute;top:-8px;right:12px;font-family:'Bebas Neue',sans-serif;font-size:100px;color:rgba(242,237,228,.03);line-height:1}
.rv-stars{color:var(--amber);font-size:11px;letter-spacing:3px;margin-bottom:14px}
.rv-text{font-size:13px;color:rgba(242,237,228,.5);line-height:1.7;margin-bottom:22px;font-style:italic}
.rv-author{display:flex;align-items:center;gap:10px}
.rv-av{width:34px;height:34px;border-radius:50%;background:rgba(191,139,46,.12);border:1px solid rgba(191,139,46,.2);display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:13px;color:var(--amber)}
.rv-name{font-size:12px;font-weight:500}
.rv-loc{font-size:10px;color:rgba(242,237,228,.22);letter-spacing:.08em}

/* ─ CLOSING ─ */
.closing-ghost{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Bebas Neue',sans-serif;font-size:clamp(80px,16vw,200px);white-space:nowrap;-webkit-text-stroke:1px rgba(242,237,228,.05);color:transparent;pointer-events:none;letter-spacing:-.02em;z-index:2;will-change:transform}
.closing-h{font-family:'Bebas Neue',sans-serif;font-size:clamp(48px,9vw,120px);line-height:.9;letter-spacing:-.01em;margin-bottom:32px}
.closing-h span{color:var(--red)}
.closing-sub{font-size:14px;color:rgba(242,237,228,.38);max-width:420px;line-height:1.8;margin-bottom:44px}
.closing-btns{display:flex;gap:14px;flex-wrap:wrap;justify-content:center}

/* ─ FOOTER ─ */
footer{position:relative;z-index:2;padding:56px 48px 110px;border-top:1px solid var(--line);display:grid;grid-template-columns:1.2fr 1fr 1fr;gap:40px;align-items:end}
.ft-logo{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:.12em;margin-bottom:10px}
.ft-addr{font-size:11px;color:rgba(242,237,228,.22);line-height:2.1;letter-spacing:.04em}
.ft-links{display:flex;flex-direction:column;gap:10px}
.ft-lk{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:rgba(242,237,228,.22);text-decoration:none;transition:color .2s}
.ft-lk:hover{color:var(--amber)}
.ft-copy{font-family:'JetBrains Mono',monospace;font-size:9px;color:rgba(242,237,228,.1);line-height:1.9;text-align:right;letter-spacing:.06em}

/* ─ STICKY ─ */
#stick{position:fixed;bottom:0;left:0;right:0;z-index:600;background:#25D366;display:flex;align-items:center;justify-content:center;gap:14px;padding:15px 24px;text-decoration:none;font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:.2em;text-transform:uppercase;color:#fff;transform:translateY(100%);transition:transform .4s cubic-bezier(.23,1,.32,1);box-shadow:0 -4px 40px rgba(37,211,102,.25)}
#stick.on{transform:translateY(0)}
.sp{width:7px;height:7px;background:rgba(255,255,255,.6);border-radius:50%;animation:sp 1.5s infinite}
@keyframes sp{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(1.6)}}

@media(max-width:900px){
  nav{padding:18px 20px}
  .nav-lk{display:none}
  .scene-content{padding:0 20px 56px}
  .hero-h{font-size:clamp(56px,14vw,100px)}
  .hero-foot{flex-direction:column;gap:24px}
  .hero-desc{max-width:100%}
  .hero-actions{align-items:flex-start}
  .scroll-hint{display:none}
  .products-wrap{padding:60px 20px}
  .p-row{grid-template-columns:1fr auto;gap:12px;padding:18px 0}
  .p-num,.p-badge,.p-btn{display:none}
  .combo-card{padding:36px 24px;max-width:100%}
  .cats-content{padding:60px 20px}
  .cat-grid{grid-template-columns:repeat(2,1fr)}
  .proof-nums{grid-template-columns:repeat(2,1fr)}
  .reviews-wrap{padding:60px 20px}
  .rv-grid{grid-template-columns:1fr}
  footer{grid-template-columns:1fr;padding:40px 20px 100px}
  .ft-copy{text-align:left}
}
</style>
</head>
<body>

<div id="cur"></div>
<div id="cur-ring"></div>

<!-- LOADER -->
<div id="loader">
  <div class="ld-word"><span id="lw1">EMPÓRIO</span></div>
  <div class="ld-word" style="-webkit-text-stroke:1px rgba(242,237,228,.2);color:transparent"><span id="lw2">SÃO VICENTE</span></div>
  <div class="ld-sub"><span id="lw3">Franca · SP · Bebidas</span></div>
  <div class="ld-progress" id="ldprog"></div>
</div>

<!-- NAV -->
<nav id="nav">
  <a href="#" class="nav-logo">ESV</a>
  <div class="nav-r">
    <a href="#products" class="nav-lk">Produtos</a>
    <a href="#scene-combo" class="nav-lk">Combos</a>
    <a href="#scene-cats" class="nav-lk">Categorias</a>
    <a href="https://wa.me/551630302676?text=Olá!%20Vi%20o%20site%20e%20quero%20pedir!" target="_blank" class="nav-btn">Pedir Agora ↗</a>
  </div>
</nav>

<!-- ══ HERO ══ -->
<section class="scene" id="hero">
  <div class="scene-bg" id="heroBg"><canvas id="cvHero"></canvas></div>
  <div class="scene-vignette" style="background:linear-gradient(to top,rgba(6,4,14,1) 0%,rgba(6,4,14,.55) 40%,rgba(6,4,14,.15) 100%),linear-gradient(to right,rgba(6,4,14,.65) 0%,transparent 55%)"></div>
  <div class="scene-grain"></div>
  <div class="scene-content">
    <p class="hero-kicker" id="hKick">📍 Av. São Vicente, 5121 · Franca-SP · Aberto até 22h</p>
    <h1 class="hero-h">
      <span class="hl"><span id="hl1">BEBA</span></span>
      <span class="hl stroke"><span id="hl2">MELHOR,</span></span>
      <span class="hl red"><span id="hl3">PAGUE</span></span>
      <span class="hl"><span id="hl4">MENOS.</span></span>
    </h1>
    <div class="hero-foot" id="hFoot">
      <p class="hero-desc">As melhores bebidas de Franca com os preços mais baixos da região. Delivery expresso ou retire na loja.</p>
      <div class="hero-actions">
        <a href="https://wa.me/551630302676?text=Oi!%20Quero%20ver%20as%20promoções!" target="_blank" class="btn-wpp">💬 &nbsp;Pedir no WhatsApp</a>
        <a href="#products" class="btn-ghost">Ver Ofertas ↓</a>
      </div>
      <div class="scroll-hint">Scroll para baixo</div>
    </div>
  </div>
</section>

<!-- TICKER -->
<div class="ticker">
  <div class="t-track">
    <span class="t-item"><em>🥃</em> Jack Daniel's · R$135</span>
    <span class="t-item"><em>🍸</em> Tanqueray Gin · R$109</span>
    <span class="t-item"><em>🍾</em> Absolut Vodka · R$74</span>
    <span class="t-item"><em>🍺</em> Heineken 12un · R$74</span>
    <span class="t-item"><em>⚡</em> Red Bull 24un · R$169</span>
    <span class="t-item"><em>🥃</em> Red Label · R$89</span>
    <span class="t-item"><em>🎯</em> Combo 3 garrafas · R$359</span>
    <span class="t-item"><em>🥃</em> Jack Daniel's · R$135</span>
