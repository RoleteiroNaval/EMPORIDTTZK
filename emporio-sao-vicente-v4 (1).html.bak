</a>

<script>
// ══════════════════════════════════════════════════
// CANVAS ART — Cinematic bar/whisky scenes rendered
// Each scene gets its own procedural painting
// ══════════════════════════════════════════════════

function resizeCanvas(cv, container) {
  const rect = container.getBoundingClientRect();
  const W = Math.max(window.innerWidth, 800);
  const H = Math.max(window.innerHeight, 600);
  cv.width = W * 1.2;
  cv.height = H * 1.2;
  return [cv.width, cv.height];
}

// ── SCENE 1: HERO — Dark bar with bokeh lights & bottles ──
function drawHero(cv) {
  const ctx = cv.getContext('2d');
  const W = cv.width, H = cv.height;

  // Deep dark bar background
  const bg = ctx.createLinearGradient(0, 0, W, H);
  bg.addColorStop(0, '#0A0614');
  bg.addColorStop(0.4, '#110820');
  bg.addColorStop(1, '#05030A');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Wood bar counter texture (bottom third)
  const wood = ctx.createLinearGradient(0, H * 0.65, 0, H);
  wood.addColorStop(0, '#1A0E06');
  wood.addColorStop(0.3, '#251208');
  wood.addColorStop(0.6, '#1E0F07');
  wood.addColorStop(1, '#120800');
  ctx.fillStyle = wood;
  ctx.fillRect(0, H * 0.65, W, H * 0.35);

  // Wood grain lines
  ctx.save();
  ctx.globalAlpha = 0.06;
  for (let i = 0; i < 40; i++) {
    const y = H * 0.65 + Math.random() * H * 0.35;
    ctx.beginPath();
    ctx.moveTo(0, y);
    ctx.bezierCurveTo(W * 0.3, y + (Math.random() - 0.5) * 8,
                      W * 0.7, y + (Math.random() - 0.5) * 8, W, y);
    ctx.strokeStyle = Math.random() > 0.5 ? '#3D1F08' : '#0D0500';
    ctx.lineWidth = Math.random() * 2 + 0.5;
    ctx.stroke();
  }
  ctx.restore();

  // Bar shelf divider line
  ctx.save();
  ctx.globalAlpha = 0.4;
  const shelfGrad = ctx.createLinearGradient(0, 0, W, 0);
  shelfGrad.addColorStop(0, 'transparent');
  shelfGrad.addColorStop(0.2, '#8B6020');
  shelfGrad.addColorStop(0.8, '#8B6020');
  shelfGrad.addColorStop(1, 'transparent');
  ctx.fillStyle = shelfGrad;
  ctx.fillRect(0, H * 0.648, W, 2);
  ctx.restore();

  // Back wall — dark warm tone
  const wall = ctx.createLinearGradient(0, 0, 0, H * 0.65);
  wall.addColorStop(0, '#0D0918');
  wall.addColorStop(0.5, '#160B1F');
  wall.addColorStop(1, '#1A0D10');
  ctx.fillStyle = wall;
  ctx.fillRect(0, 0, W, H * 0.65);

  // Mirror/glass reflection behind bottles — lighter strip
  const mirror = ctx.createLinearGradient(0, H * 0.1, 0, H * 0.65);
  mirror.addColorStop(0, 'rgba(255,200,100,0.03)');
  mirror.addColorStop(0.5, 'rgba(255,180,80,0.06)');
  mirror.addColorStop(1, 'rgba(200,100,30,0.04)');
  ctx.fillStyle = mirror;
  ctx.fillRect(W * 0.1, H * 0.1, W * 0.8, H * 0.55);

  // ── BOTTLES (silhouettes) ──
  function drawBottle(x, y, h, w, color, highlight, label) {
    ctx.save();
    // Bottle body
    const grad = ctx.createLinearGradient(x - w/2, 0, x + w/2, 0);
    grad.addColorStop(0, 'rgba(0,0,0,0.8)');
    grad.addColorStop(0.2, color);
    grad.addColorStop(0.5, highlight);
    grad.addColorStop(0.8, color);
    grad.addColorStop(1, 'rgba(0,0,0,0.8)');
    ctx.fillStyle = grad;

    // Bottle shape
    ctx.beginPath();
    ctx.moveTo(x - w * 0.38, y);           // bottom left
    ctx.lineTo(x + w * 0.38, y);           // bottom right
    ctx.lineTo(x + w * 0.38, y - h * 0.6); // right side
    ctx.bezierCurveTo(x + w * 0.38, y - h * 0.75, x + w * 0.18, y - h * 0.78, x + w * 0.12, y - h * 0.82);
    ctx.lineTo(x + w * 0.12, y - h * 0.92);
    ctx.lineTo(x + w * 0.06, y - h);       // top right neck
    ctx.lineTo(x - w * 0.06, y - h);       // top left neck
    ctx.lineTo(x - w * 0.12, y - h * 0.92);
    ctx.lineTo(x - w * 0.12, y - h * 0.82);
    ctx.bezierCurveTo(x - w * 0.18, y - h * 0.78, x - w * 0.38, y - h * 0.75, x - w * 0.38, y - h * 0.6);
    ctx.closePath();
    ctx.fill();

    // Bottle highlight stripe
    ctx.fillStyle = `rgba(255,255,255,0.06)`;
    ctx.beginPath();
    ctx.moveTo(x - w * 0.05, y);
    ctx.lineTo(x + w * 0.08, y);
    ctx.lineTo(x + w * 0.06, y - h * 0.6);
    ctx.lineTo(x - w * 0.02, y - h * 0.6);
    ctx.closePath();
    ctx.fill();

    // Label area
    if (label) {
      const lg = ctx.createLinearGradient(x - w * 0.3, 0, x + w * 0.3, 0);
      lg.addColorStop(0, 'rgba(0,0,0,0)');
      lg.addColorStop(0.3, label);
      lg.addColorStop(0.7, label);
      lg.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = lg;
      ctx.fillRect(x - w * 0.3, y - h * 0.55, w * 0.6, h * 0.22);
    }

    // Reflection on bar
    ctx.globalAlpha = 0.12;
    ctx.scale(1, -0.25);
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.moveTo(x - w * 0.38, -(y));
    ctx.lineTo(x + w * 0.38, -(y));
    ctx.lineTo(x + w * 0.38, -(y - h * 0.4));
    ctx.lineTo(x - w * 0.38, -(y - h * 0.4));
    ctx.closePath();
    ctx.fill();
    ctx.restore();
  }

  // Draw bottles on shelf
  const bottles = [
    { x: W*0.08, h: H*0.38, w: 28, c: 'rgba(60,30,10,0.9)', hi: 'rgba(120,60,20,0.7)', lbl: 'rgba(180,140,60,0.3)' },
    { x: W*0.14, h: H*0.44, w: 26, c: 'rgba(20,50,20,0.9)', hi: 'rgba(40,90,40,0.7)', lbl: 'rgba(80,160,80,0.2)' },
    { x: W*0.20, h: H*0.40, w: 30, c: 'rgba(80,30,10,0.9)', hi: 'rgba(160,60,20,0.7)', lbl: 'rgba(220,180,60,0.3)' },
    { x: W*0.26, h: H*0.48, w: 24, c: 'rgba(30,30,60,0.9)', hi: 'rgba(60,60,110,0.7)', lbl: 'rgba(100,100,200,0.2)' },
    { x: W*0.32, h: H*0.42, w: 32, c: 'rgba(50,20,5,0.9)',  hi: 'rgba(120,50,10,0.8)', lbl: 'rgba(200,150,50,0.35)' },
    { x: W*0.72, h: H*0.45, w: 28, c: 'rgba(60,25,8,0.9)',  hi: 'rgba(130,55,15,0.7)', lbl: 'rgba(210,160,50,0.3)' },
    { x: W*0.78, h: H*0.50, w: 26, c: 'rgba(15,45,15,0.9)', hi: 'rgba(35,85,35,0.7)', lbl: 'rgba(70,150,70,0.2)' },
    { x: W*0.84, h: H*0.38, w: 30, c: 'rgba(70,25,8,0.9)',  hi: 'rgba(150,55,15,0.7)', lbl: 'rgba(220,170,55,0.3)' },
    { x: W*0.90, h: H*0.46, w: 24, c: 'rgba(8,8,30,0.9)',   hi: 'rgba(25,25,70,0.7)',  lbl: 'rgba(80,80,180,0.2)' },
    { x: W*0.96, h: H*0.42, w: 28, c: 'rgba(55,20,6,0.9)',  hi: 'rgba(120,45,12,0.7)', lbl: 'rgba(200,155,45,0.3)' },
  ];
  const barY = H * 0.648;
  bottles.forEach(b => drawBottle(b.x, barY, b.h, b.w, b.c, b.hi, b.lbl));

  // ── BOKEH LIGHTS (warm bar ambiance) ──
  const bokehs = [
    { x: W*0.5, y: H*0.15, r: 180, c: 'rgba(255,180,60,0.07)' },
    { x: W*0.15, y: H*0.3, r: 100, c: 'rgba(255,120,30,0.05)' },
    { x: W*0.85, y: H*0.25, r: 120, c: 'rgba(255,200,80,0.06)' },
    { x: W*0.35, y: H*0.55, r: 80, c:  'rgba(255,150,50,0.04)' },
    { x: W*0.7,  y: H*0.5,  r: 90, c:  'rgba(255,160,60,0.05)' },
  ];
  bokehs.forEach(b => {
    const g = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, b.r);
    g.addColorStop(0, b.c);
    g.addColorStop(1, 'transparent');
    ctx.fillStyle = g;
    ctx.beginPath(); ctx.arc(b.x, b.y, b.r, 0, Math.PI*2); ctx.fill();
  });

  // Small bokeh dots
  ctx.save();
  for (let i = 0; i < 60; i++) {
    const x = Math.random() * W;
    const y = Math.random() * H * 0.65;
    const r = Math.random() * 6 + 1;
    const alpha = Math.random() * 0.18 + 0.02;
    const hue = Math.random() > 0.6 ? `rgba(255,${180+Math.random()*60},${40+Math.random()*60},${alpha})` : `rgba(255,${200+Math.random()*55},${100+Math.random()*80},${alpha})`;
    const g = ctx.createRadialGradient(x, y, 0, x, y, r);
    g.addColorStop(0, hue);
    g.addColorStop(1, 'transparent');
    ctx.fillStyle = g;
    ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI*2); ctx.fill();
  }
  ctx.restore();

  // Overhead light beam from ceiling
  const beam = ctx.createRadialGradient(W * 0.5, 0, 0, W * 0.5, 0, H * 0.7);
  beam.addColorStop(0, 'rgba(255,200,100,0.04)');
  beam.addColorStop(0.6, 'rgba(255,160,60,0.015)');
  beam.addColorStop(1, 'transparent');
  ctx.fillStyle = beam;
  ctx.fillRect(0, 0, W, H);

  // Subtle dust motes
  ctx.save();
  ctx.globalAlpha = 0.4;
  for (let i = 0; i < 30; i++) {
    const x = Math.random() * W;
    const y = Math.random() * H * 0.6;
    ctx.fillStyle = 'rgba(255,220,150,0.08)';
    ctx.beginPath();
    ctx.arc(x, y, Math.random() * 1.5 + 0.3, 0, Math.PI*2);
    ctx.fill();
  }
  ctx.restore();
}

// ── SCENE 2: STATEMENT — Whisky glass macro ──
function drawStatement(cv) {
  const ctx = cv.getContext('2d');
  const W = cv.width, H = cv.height;

  const bg = ctx.createRadialGradient(W*0.5, H*0.5, 0, W*0.5, H*0.5, W*0.8);
  bg.addColorStop(0, '#1A0D04');
  bg.addColorStop(0.4, '#0E0708');
  bg.addColorStop(1, '#060309');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Glass silhouette (wide whisky glass / tumbler)
  function drawGlass(cx, cy, r) {
    const topW = r * 0.9, botW = r * 0.6, gh = r * 1.4;
    ctx.save();

    // Glass body gradient
    const gg = ctx.createLinearGradient(cx - topW, 0, cx + topW, 0);
    gg.addColorStop(0, 'rgba(0,0,0,0.9)');
    gg.addColorStop(0.12, 'rgba(180,120,60,0.12)');
    gg.addColorStop(0.4, 'rgba(220,150,70,0.08)');
    gg.addColorStop(0.5, 'rgba(255,200,100,0.15)');
    gg.addColorStop(0.7, 'rgba(200,130,50,0.07)');
    gg.addColorStop(0.9, 'rgba(180,100,40,0.1)');
    gg.addColorStop(1, 'rgba(0,0,0,0.9)');

    ctx.beginPath();
    ctx.moveTo(cx - botW, cy);
    ctx.lineTo(cx + botW, cy);
    ctx.lineTo(cx + topW, cy - gh);
    ctx.lineTo(cx - topW, cy - gh);
    ctx.closePath();
    ctx.fillStyle = gg;
    ctx.fill();

    // Liquid (whisky amber)
    const liqH = gh * 0.45;
    const liqG = ctx.createLinearGradient(0, cy - liqH, 0, cy);
    liqG.addColorStop(0, 'rgba(180,100,20,0.35)');
    liqG.addColorStop(0.5, 'rgba(210,130,30,0.5)');
    liqG.addColorStop(1, 'rgba(150,70,10,0.6)');

    // Calculate liquid edges at those heights
    const t = 1 - liqH / gh;
    const liqLx = cx - (botW + (topW - botW) * (1 - t));
    const liqRx = cx + (botW + (topW - botW) * (1 - t));

    ctx.beginPath();
    ctx.moveTo(cx - botW, cy);
    ctx.lineTo(cx + botW, cy);
    ctx.lineTo(liqRx, cy - liqH);
    ctx.bezierCurveTo(liqRx - 10, cy - liqH - 6, liqLx + 10, cy - liqH + 4, liqLx, cy - liqH);
    ctx.closePath();
    ctx.fillStyle = liqG;
    ctx.fill();

    // Liquid surface shimmer
    ctx.fillStyle = 'rgba(255,200,80,0.12)';
    ctx.beginPath();
    ctx.ellipse(cx, cy - liqH, (liqRx - liqLx) / 2, 4, 0, 0, Math.PI*2);
    ctx.fill();

    // Glass rim highlight
    ctx.strokeStyle = 'rgba(255,230,150,0.18)';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(cx - topW, cy - gh);
    ctx.lineTo(cx + topW, cy - gh);
    ctx.stroke();

    // Ice cube suggestion
    ctx.fillStyle = 'rgba(200,230,255,0.08)';
    ctx.fillRect(cx - 20, cy - liqH + 8, 35, 28);
    ctx.fillStyle = 'rgba(200,230,255,0.05)';
    ctx.fillRect(cx + 10, cy - liqH + 18, 25, 20);

    ctx.restore();
  }

  // Main glass centered
  drawGlass(W * 0.55, H * 0.75, 180);

  // Blurred secondary glass (depth)
  ctx.globalAlpha = 0.3;
  drawGlass(W * 0.15, H * 0.8, 100);
  drawGlass(W * 0.88, H * 0.82, 80);
  ctx.globalAlpha = 1;

  // Warm amber light from below glass
  const glow = ctx.createRadialGradient(W*0.55, H*0.82, 0, W*0.55, H*0.82, 250);
  glow.addColorStop(0, 'rgba(200,110,20,0.12)');
  glow.addColorStop(0.5, 'rgba(180,90,15,0.06)');
  glow.addColorStop(1, 'transparent');
  ctx.fillStyle = glow;
  ctx.beginPath(); ctx.arc(W*0.55, H*0.82, 250, 0, Math.PI*2); ctx.fill();

  // Bokeh circles (out of focus)
  [
    {x:.2,y:.2,r:80,a:.06},{x:.8,y:.15,r:60,a:.05},
    {x:.1,y:.5,r:50,a:.04},{x:.9,y:.4,r:70,a:.05},
    {x:.6,y:.1,r:90,a:.04},{x:.3,y:.7,r:55,a:.04},
  ].forEach(b => {
    const g = ctx.createRadialGradient(W*b.x,H*b.y,0,W*b.x,H*b.y,b.r);
    g.addColorStop(0, `rgba(220,150,50,${b.a})`);
    g.addColorStop(1,'transparent');
    ctx.fillStyle=g; ctx.beginPath(); ctx.arc(W*b.x,H*b.y,b.r,0,Math.PI*2); ctx.fill();
  });
}

// ── SCENE 3: COMBO — Party/celebration lighting ──
function drawCombo(cv) {
  const ctx = cv.getContext('2d');
  const W = cv.width, H = cv.height;

  // Dark base
  ctx.fillStyle = '#07040F';
  ctx.fillRect(0, 0, W, H);

  // Multiple colored light sources (party bar)
  const lights = [
    { x: W*0.2, y: 0, r: H*0.9, c1: 'rgba(200,40,40,0.09)', c2: 'transparent' },
    { x: W*0.8, y: 0, r: H*0.8, c1: 'rgba(180,100,20,0.1)', c2: 'transparent' },
    { x: W*0.5, y: H*0.1, r: H*0.6, c1: 'rgba(255,180,50,0.07)', c2: 'transparent' },
    { x: W*0.1, y: H*0.5, r: H*0.5, c1: 'rgba(150,30,30,0.06)', c2: 'transparent' },
    { x: W*0.9, y: H*0.6, r: H*0.4, c1: 'rgba(220,140,30,0.07)', c2: 'transparent' },
  ];
  lights.forEach(l => {
    const g = ctx.createRadialGradient(l.x,l.y,0,l.x,l.y,l.r);
    g.addColorStop(0, l.c1); g.addColorStop(1, l.c2);
    ctx.fillStyle = g;
    ctx.fillRect(0,0,W,H);
  });

  // Bottles silhouettes (multiple, celebration)
  ctx.save();
  const bottleColors = [
    'rgba(60,25,8,0.85)', 'rgba(20,55,20,0.85)', 'rgba(10,10,40,0.85)',
    'rgba(80,35,10,0.85)', 'rgba(50,20,5,0.9)', 'rgba(30,10,40,0.85)',
  ];
  for (let i = 0; i < 6; i++) {
    const bx = W * (0.1 + i * 0.16);
    const by = H * (0.55 + Math.sin(i * 1.2) * 0.06);
    const bh = H * (0.3 + Math.random() * 0.15);
    const bw = 22 + Math.random() * 12;
    const c = bottleColors[i];

    const bg2 = ctx.createLinearGradient(bx - bw/2, 0, bx + bw/2, 0);
    bg2.addColorStop(0, 'rgba(0,0,0,0.9)');
    bg2.addColorStop(0.3, c);
    bg2.addColorStop(0.5, c.replace('0.8', '0.6').replace('0.9', '0.7'));
    bg2.addColorStop(0.8, c);
    bg2.addColorStop(1, 'rgba(0,0,0,0.9)');

    ctx.globalAlpha = 0.7 + Math.random() * 0.3;
    ctx.fillStyle = bg2;
    ctx.beginPath();
    ctx.moveTo(bx - bw*0.4, by);
    ctx.lineTo(bx + bw*0.4, by);
    ctx.lineTo(bx + bw*0.35, by - bh*0.65);
    ctx.bezierCurveTo(bx + bw*0.35, by-bh*0.78, bx+bw*0.14, by-bh*0.8, bx+bw*0.1, by-bh*0.88);
    ctx.lineTo(bx + bw*0.07, by-bh);
    ctx.lineTo(bx - bw*0.07, by-bh);
    ctx.lineTo(bx - bw*0.1, by-bh*0.88);
    ctx.bezierCurveTo(bx-bw*0.14, by-bh*0.8, bx-bw*0.35, by-bh*0.78, bx-bw*0.35, by-bh*0.65);
    ctx.closePath();
    ctx.fill();
  }
  ctx.restore();

  // Confetti/sparkle dots
  ctx.save();
  for (let i = 0; i < 80; i++) {
    const x = Math.random() * W;
    const y = Math.random() * H * 0.7;
    const r = Math.random() * 3 + 0.5;
    const colors = ['rgba(255,215,0,', 'rgba(255,100,100,', 'rgba(255,180,50,', 'rgba(200,200,255,'];
    const col = colors[Math.floor(Math.random() * colors.length)];
    ctx.globalAlpha = Math.random() * 0.3 + 0.05;
    const gd = ctx.createRadialGradient(x,y,0,x,y,r*3);
    gd.addColorStop(0, col+'0.8)');
    gd.addColorStop(1, col+'0)');
    ctx.fillStyle = gd;
    ctx.beginPath(); ctx.arc(x,y,r*3,0,Math.PI*2); ctx.fill();
  }
  ctx.restore();
}

// ── SCENE 4: PROOF — Aerial bar top view ──
function drawProof(cv) {
  const ctx = cv.getContext('2d');
  const W = cv.width, H = cv.height;

  ctx.fillStyle = '#08060F';
  ctx.fillRect(0, 0, W, H);

  // Bar top surface (marble/stone)
  const marble = ctx.createLinearGradient(0, H*0.3, 0, H);
  marble.addColorStop(0, '#0F0A18');
  marble.addColorStop(0.5, '#150D20');
  marble.addColorStop(1, '#0A0715');
  ctx.fillStyle = marble;
  ctx.fillRect(0, H*0.2, W, H*0.8);

  // Marble veins
  ctx.save();
  ctx.globalAlpha = 0.04;
  for (let i = 0; i < 12; i++) {
    ctx.beginPath();
    const sx = Math.random() * W;
    const sy = H * 0.2 + Math.random() * H * 0.8;
    ctx.moveTo(sx, sy);
    ctx.bezierCurveTo(
      sx + (Math.random()-0.5)*200, sy + (Math.random()-0.5)*100,
      sx + (Math.random()-0.5)*200, sy + (Math.random()-0.5)*100,
      sx + (Math.random()-0.5)*400, sy + (Math.random()-0.5)*200
    );
    ctx.strokeStyle = Math.random() > 0.5 ? '#9B7FD4' : '#7060B0';
    ctx.lineWidth = Math.random() * 3 + 0.5;
    ctx.stroke();
  }
  ctx.restore();

  // Top-down view glasses
  function drawGlassTop(cx, cy, r, fillColor) {
    // Glass rim
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(255,220,150,0.25)';
    ctx.lineWidth = 1.5;
    ctx.stroke();
    // Liquid
    const lg = ctx.createRadialGradient(cx, cy, 0, cx, cy, r*0.88);
    lg.addColorStop(0, fillColor);
    lg.addColorStop(1, fillColor.replace(/[\d.]+\)$/, '0.2)'));
    ctx.fillStyle = lg;
    ctx.beginPath();
    ctx.arc(cx, cy, r*0.88, 0, Math.PI*2);
    ctx.fill();
    // Ice reflection
    ctx.fillStyle = 'rgba(200,230,255,0.12)';
    ctx.beginPath();
    ctx.ellipse(cx - r*0.2, cy - r*0.2, r*0.25, r*0.18, -0.4, 0, Math.PI*2);
    ctx.fill();
  }

  drawGlassTop(W*0.25, H*0.55, 70, 'rgba(180,100,20,0.4)'); // whisky
  drawGlassTop(W*0.6,  H*0.45, 50, 'rgba(120,200,120,0.3)'); // gin
  drawGlassTop(W*0.75, H*0.7,  60, 'rgba(200,180,100,0.35)'); // wine
  drawGlassTop(W*0.4,  H*0.75, 40, 'rgba(50,80,180,0.3)');   // mixer

  // Warm overhead light
  const glow = ctx.createRadialGradient(W*0.5,0,0,W*0.5,0,H*0.8);
  glow.addColorStop(0,'rgba(255,180,60,0.06)');
  glow.addColorStop(1,'transparent');
  ctx.fillStyle=glow; ctx.fillRect(0,0,W,H);

  // Bokeh
  for (let i = 0; i < 40; i++) {
    const x=Math.random()*W, y=Math.random()*H*0.3;
    const r=Math.random()*20+4;
    const g=ctx.createRadialGradient(x,y,0,x,y,r);
    g.addColorStop(0,'rgba(255,200,80,0.08)');
    g.addColorStop(1,'transparent');
    ctx.fillStyle=g; ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.fill();
  }
}

// ── SCENE 5: CLOSING — Night bar ambiance ──
function drawClosing(cv) {
  const ctx = cv.getContext('2d');
  const W = cv.width, H = cv.height;

  ctx.fillStyle = '#040208';
  ctx.fillRect(0,0,W,H);

  // Deep red/amber atmosphere
  const atm = ctx.createRadialGradient(W*0.5,H*0.4,0,W*0.5,H*0.4,W*0.7);
  atm.addColorStop(0,'rgba(150,30,10,0.15)');
  atm.addColorStop(0.5,'rgba(100,20,5,0.08)');
  atm.addColorStop(1,'transparent');
  ctx.fillStyle=atm; ctx.fillRect(0,0,W,H);

  // Neon sign glow effect (warm)
  const neon = ctx.createRadialGradient(W*0.5,H*0.25,0,W*0.5,H*0.25,200);
  neon.addColorStop(0,'rgba(220,80,30,0.15)');
  neon.addColorStop(0.5,'rgba(200,60,20,0.08)');
  neon.addColorStop(1,'transparent');
  ctx.fillStyle=neon; ctx.fillRect(0,0,W,H);

  // Neon sign lines
  ctx.save();
  ctx.strokeStyle='rgba(255,100,40,0.35)';
  ctx.lineWidth=2;
  ctx.shadowColor='rgba(255,100,40,0.8)';
  ctx.shadowBlur=12;
  // Simple neon tube shapes
  ctx.beginPath();
  ctx.arc(W*0.5, H*0.22, 60, Math.PI*0.2, Math.PI*0.8);
  ctx.stroke();
  ctx.beginPath();
  ctx.arc(W*0.5, H*0.22, 60, Math.PI*1.2, Math.PI*1.8);
  ctx.stroke();
  ctx.restore();

  // Dark bottles at bottom (silhouette forest)
  ctx.save();
  ctx.fillStyle='rgba(0,0,0,0.7)';
  for (let i = 0; i < 14; i++) {
    const bx = (i / 13) * W;
    const bh = H * (0.25 + Math.sin(i * 0.9) * 0.08 + Math.random() * 0.06);
    const bw = 20 + Math.random() * 18;
    const by = H;
    ctx.beginPath();
    ctx.moveTo(bx - bw*0.4, by);
    ctx.lineTo(bx + bw*0.4, by);
    ctx.lineTo(bx + bw*0.35, by - bh*0.6);
    ctx.lineTo(bx + bw*0.12, by - bh*0.78);
    ctx.lineTo(bx + bw*0.08, by - bh);
    ctx.lineTo(bx - bw*0.08, by - bh);
    ctx.lineTo(bx - bw*0.12, by - bh*0.78);
    ctx.lineTo(bx - bw*0.35, by - bh*0.6);
    ctx.closePath();
    ctx.fill();
  }
  ctx.restore();

  // Stars/bokeh
  for (let i=0;i<50;i++){
    const x=Math.random()*W,y=Math.random()*H*0.5;
    const r=Math.random()*8+2;
    const g=ctx.createRadialGradient(x,y,0,x,y,r);
    g.addColorStop(0,'rgba(255,180,80,0.1)');
    g.addColorStop(1,'transparent');
    ctx.fillStyle=g; ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.fill();
  }
}

// ── PRODUCTS BG: subtle whisky swirl ──
function drawProductsBg(cv) {
  const ctx = cv.getContext('2d');
  const W = cv.width, H = cv.height;
  ctx.clearRect(0,0,W,H);
  // Amber swirl / pour
  const g = ctx.createLinearGradient(W*0.6, 0, W, H);
  g.addColorStop(0,'rgba(180,100,20,0.15)');
  g.addColorStop(0.5,'rgba(150,80,15,0.1)');
  g.addColorStop(1,'rgba(100,50,10,0.05)');
  ctx.fillStyle=g;
  ctx.beginPath();
  ctx.moveTo(W*0.6,0); ctx.lineTo(W,0); ctx.lineTo(W,H); ctx.lineTo(W*0.5,H);
  ctx.bezierCurveTo(W*0.7,H*0.6,W*0.5,H*0.4,W*0.6,0);
  ctx.fill();
  for (let i=0;i<20;i++){
    const x=W*0.65+Math.random()*W*0.35;
    const y=Math.random()*H;
    const r=Math.random()*40+10;
    const gd=ctx.createRadialGradient(x,y,0,x,y,r);
    gd.addColorStop(0,'rgba(200,130,30,0.06)');
    gd.addColorStop(1,'transparent');
    ctx.fillStyle=gd; ctx.beginPath(); ctx.arc(x,y,r,0,Math.PI*2); ctx.fill();
  }
}

// ── CATEGORIES BG: bottle grid pattern ──
function drawCatsBg(cv) {
  const ctx = cv.getContext('2d');
  const W = cv.width, H = cv.height;
  ctx.clearRect(0,0,W,H);
  const g = ctx.createLinearGradient(0,0,W*0.5,H);
  g.addColorStop(0,'rgba(150,80,20,0.12)');
  g.addColorStop(1,'transparent');
  ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
  // dot grid pattern
  ctx.fillStyle='rgba(200,150,50,0.04)';
  for(let x=0;x<W;x+=32) for(let y=0;y<H;y+=32){
    ctx.beginPath(); ctx.arc(x,y,1,0,Math.PI*2); ctx.fill();
  }
}

// ── INIT: draw all canvases ──
function initCanvases() {
  const scenes = [
    { cv: document.getElementById('cvHero'), draw: drawHero, container: document.getElementById('heroBg') },
    { cv: document.getElementById('cvStmt'), draw: drawStatement, container: document.getElementById('stmtBg') },
    { cv: document.getElementById('cvCombo'), draw: drawCombo, container: document.getElementById('comboBg') },
    { cv: document.getElementById('cvProof'), draw: drawProof, container: document.getElementById('proofBg') },
    { cv: document.getElementById('cvClosing'), draw: drawClosing, container: document.getElementById('closingBg') },
    { cv: document.getElementById('cvProducts'), draw: drawProductsBg, container: null },
    { cv: document.getElementById('cvCats'), draw: drawCatsBg, container: null },
  ];

  scenes.forEach(s => {
    if (!s.cv) return;
    const W = window.innerWidth * 1.2;
    const H = window.innerHeight * 1.2;
    s.cv.width = W; s.cv.height = H;
    s.draw(s.cv);
  });
}

// ══ GSAP ANIMATIONS ══════════════════════════════
gsap.registerPlugin(ScrollTrigger);

window.addEventListener('load', () => {
  initCanvases();
  setTimeout(() => document.getElementById('ldprog').style.width = '200px', 100);

  const tl = gsap.timeline();
  tl.to(['#lw1','#lw2','#lw3'], {y:0, duration:.9, stagger:.15, ease:'power3.out', delay:.2})
    .to('#loader', {opacity:0, duration:.7, ease:'power2.inOut', delay:.6})
    .set('#loader', {display:'none'})
    .call(startSite);
});

function startSite() {
  // Hero entrance
  gsap.timeline()
    .to(['#hl1','#hl2','#hl3','#hl4'], {y:0, duration:1.1, stagger:.1, ease:'power3.out'})
    .to('#hKick', {opacity:1, duration:.7, ease:'power2.out'}, .2)
    .to('#hFoot', {opacity:1, duration:.9, ease:'power2.out'}, .5);

  // Parallax on all scene-bg canvases
  document.querySelectorAll('.scene-bg').forEach(bg => {
    gsap.fromTo(bg,
      {yPercent:-8},
      {yPercent:8, ease:'none',
       scrollTrigger:{trigger:bg.closest('.scene'),start:'top bottom',end:'bottom top',scrub:1.5}});
  });

  // Hero title parallax
  gsap.to('.hero-h', {yPercent:20, ease:'none',
    scrollTrigger:{trigger:'#hero',start:'top top',end:'bottom top',scrub:1}});

  // Closing ghost drift
  gsap.to('#cGhost', {xPercent:-25, ease:'none',
    scrollTrigger:{trigger:'#scene-closing',start:'top bottom',end:'bottom top',scrub:1.2}});

  // Reveal animations
  gsap.from('.stmt-h', {
    scrollTrigger:{trigger:'#scene-stmt',start:'top 65%'},
    opacity:0, y:70, duration:1.1, ease:'power3.out'});

  gsap.from('.prod-header', {
    scrollTrigger:{trigger:'#products',start:'top 85%'},
    opacity:0, y:40, duration:.8, ease:'power3.out'});

  gsap.utils.toArray('.p-row').forEach((r,i) => {
    gsap.from(r, {
      scrollTrigger:{trigger:r,start:'top 92%'},
      opacity:0, x:-50, duration:.75, ease:'power2.out', delay:i*.08});
  });

  gsap.from('.combo-card', {
    scrollTrigger:{trigger:'#scene-combo',start:'top 60%'},
    opacity:0, y:60, x:-40, duration:1, ease:'power3.out'});

  gsap.from('.combo-num-big', {
    scrollTrigger:{trigger:'#scene-combo',start:'top 55%'},
    opacity:0, scale:.7, duration:1.1, ease:'elastic.out(1,.6)', delay:.2});

  gsap.utils.toArray('.c-cell').forEach((c,i) => {
    gsap.from(c, {
      scrollTrigger:{trigger:c,start:'top 92%'},
      opacity:0, scale:.88, duration:.55, ease:'back.out(1.5)', delay:i*.04});
  });

  gsap.from('.proof-nums', {
    scrollTrigger:{trigger:'#scene-proof',start:'top 60%'},
    opacity:0, y:50, duration:1, ease:'power3.out'});

  gsap.utils.toArray('.rv-card').forEach((c,i) => {
    gsap.from(c, {
      scrollTrigger:{trigger:c,start:'top 90%'},
      opacity:0, y:40, duration:.75, ease:'power3.out', delay:i*.12});
  });

  gsap.from('.closing-h,.closing-sub,.closing-btns', {
    scrollTrigger:{trigger:'#scene-closing',start:'top 70%'},
    opacity:0, y:50, duration:.9, stagger:.15, ease:'power3.out'});
}

// Cursor
const cur=document.getElementById('cur'), ring=document.getElementById('cur-ring');
let cx=0,cy=0,rx=0,ry=0,tx=0,ty=0;
document.addEventListener('mousemove',e=>{tx=e.clientX;ty=e.clientY;});
(function loop(){
  cx+=(tx-cx)*.14; cy+=(ty-cy)*.14;
  rx+=(tx-rx)*.07; ry+=(ty-ry)*.07;
  cur.style.left=cx+'px'; cur.style.top=cy+'px';
  ring.style.left=rx+'px'; ring.style.top=ry+'px';
  requestAnimationFrame(loop);
})();
document.querySelectorAll('a,button,.c-cell,.p-row').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.classList.add('big');ring.style.width='80px';ring.style.height='80px';ring.style.opacity='0';});
  el.addEventListener('mouseleave',()=>{cur.classList.remove('big');ring.style.width='40px';ring.style.height='40px';ring.style.opacity='1';});
});

// Hover preview
const pv=document.getElementById('pv');
document.querySelectorAll('.p-row').forEach(r=>{
  r.addEventListener('mouseenter',()=>{pv.textContent=r.dataset.emoji||'🥃';pv.classList.add('show');});
  r.addEventListener('mousemove',e=>{pv.style.left=e.clientX+'px';pv.style.top=(e.clientY-70)+'px';});
  r.addEventListener('mouseleave',()=>pv.classList.remove('show'));
});

// Nav scroll + sticky
window.addEventListener('scroll',()=>{
  document.getElementById('nav').classList.toggle('scrolled',window.scrollY>60);
  document.getElementById('stick').classList.toggle('on',window.scrollY>window.innerHeight*.6);
});

// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    const t=document.querySelector(a.getAttribute('href'));
    if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth'});}
  });
});

// Redraw on resize
window.addEventListener('resize', ()=>{ initCanvases(); });
</script>
</body>
</html>
